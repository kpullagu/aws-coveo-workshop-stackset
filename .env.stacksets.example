# ============================================================================
# AWS StackSets Workshop Configuration Template
# ============================================================================
# Copy this file to .env.stacksets and fill in your values
# 
# IMPORTANT: .env.stacksets is in .gitignore and will NOT be committed
# ============================================================================

# ============================================================================
# AWS Organizations Configuration (REQUIRED)
# ============================================================================
# Your AWS Organizations OU ID where child accounts are located
OU_ID=ou-xxxx-xxxxxxxx

# Your master/management account ID
MASTER_ACCOUNT_ID=123456789012

# AWS Region for deployment
AWS_REGION=us-east-1

# Optional AWS CLI profile for the StackSets management/delegated admin account
# Leave blank to use the active shell credentials.
AWS_PROFILE=

# Stack prefix for all resources
STACK_PREFIX=workshop

# ============================================================================
# Coveo Configuration (REQUIRED)
# ============================================================================
# Get these from your Coveo Platform: https://platform.cloud.coveo.com

# Your Coveo Organization ID
COVEO_ORG_ID=your-org-id-here

# Coveo Search API Key (with search permissions)
COVEO_SEARCH_API_KEY=xx00000000-0000-0000-0000-000000000000

# Coveo Platform URL
COVEO_PLATFORM_URL=https://platform.cloud.coveo.com

# Workshop query pipeline and search hub
COVEO_SEARCH_PIPELINE=aws-workshop-pipeline
COVEO_SEARCH_HUB=aws-workshop

# Coveo Answer Configuration ID (for Coveo Answers)
COVEO_ANSWER_CONFIG_ID=00000000-0000-0000-0000-000000000000

# Native Coveo Search Agent with Headless (Lab 3)
# Reuses COVEO_ORG_ID, COVEO_SEARCH_API_KEY, COVEO_SEARCH_HUB, and
# COVEO_SEARCH_PIPELINE from the shared workshop configuration.
COVEO_SEARCH_AGENT_ID=00000000-0000-0000-0000-000000000000
COVEO_ENVIRONMENT=prod

# Coveo Hosted MCP Configuration
# Create and manage this in Coveo Admin Console
COVEO_HOSTED_MCP_CONFIG_NAME=Workshop-MCP-server
COVEO_HOSTED_MCP_ENDPOINT=https://platform.cloud.coveo.com/api/preview/organizations/awsworkshopthsskpki/mcp/server/f9552f36-24e1-47b6-8c55-d6fe87553c61
COVEO_HOSTED_MCP_AUTH_MODE=anonymous_api_key
COVEO_HOSTED_MCP_API_KEY=xx00000000-0000-0000-0000-000000000000
COVEO_HOSTED_MCP_SEARCH_HUB=MCP_Workshop-MCP-server

# The refreshed workshop should use the full 12-source indexed content set
WORKSHOP_EXPECTED_SOURCE_COUNT=12

# ============================================================================
# Test User Configuration (OPTIONAL)
# ============================================================================
# Credentials for Cognito test user created during deployment
TEST_USER_EMAIL=workshop-user@example.com
TEST_USER_PASSWORD=ChangeMe123!

# ============================================================================
# Bedrock Configuration (OPTIONAL)
# ============================================================================
# Bedrock model to use for the agent
BEDROCK_MODEL=us.amazon.nova-lite-v1:0

# ============================================================================
# UI Deployment Target (OPTIONAL)
# ============================================================================
# Preferred target for the workshop refresh is ECS Express Mode
UI_DEPLOY_TARGET=ecs-express
UI_CONTAINER_PORT=3003
UI_HEALTH_CHECK_PATH=/health
UI_CPU=1024
UI_MEMORY=2048

# ============================================================================
# Deployment Configuration (OPTIONAL)
# ============================================================================
# Maximum number of accounts to deploy to concurrently
MAX_CONCURRENT_ACCOUNTS=10

# Number of failures to tolerate before stopping deployment
FAILURE_TOLERANCE_COUNT=5

# Role name to assume in child accounts
ASSUME_ROLE_NAME=OrganizationAccountAccessRole
